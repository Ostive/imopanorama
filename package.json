{
  "name": "imopanorama",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:unit": "vitest --run __tests__/unit",
    "test:integration": "vitest --run __tests__/integration",
    "test:api": "vitest --run __tests__/integration/apiFlows.test.ts",
    "test:all": "vitest --run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "test:e2e:api": "playwright test e2e/api-auth-property.spec.ts",
    "test:e2e:crud": "playwright test e2e/api-auth-property.spec.ts --grep @crud",
    "test:e2e:ui": "playwright test --ui",
    "verify:e2e": "npm run test:e2e:smoke && npm run test:e2e:api",
    "check:security": "npm audit --audit-level=moderate",
    "check:deps": "npm outdated",
    "prod:check": "npx ts-node --project scripts/tsconfig.json scripts/production-check.ts",
    "verify:prod": "npm run prod:check && npm run check:security && npm run test:all && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "npx ts-node prisma/seed.ts",
    "db:seed:blog:prod": "npx ts-node prisma/seed-blog-prod.ts",
    "db:seed:properties": "npx ts-node prisma/seed-properties.ts",
    "db:status": "prisma migrate status",
    "db:deploy": "prisma migrate deploy",
    "embeddings:backfill": "npx ts-node --project scripts/tsconfig.json -r tsconfig-paths/register scripts/backfill-embeddings.ts",
    "embeddings:rebuild": "npx ts-node --project scripts/tsconfig.json -r tsconfig-paths/register scripts/backfill-embeddings.ts --force",
    "db:reset": "prisma migrate reset --force",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:reset:seed": "prisma migrate reset --force && npx ts-node prisma/seed.ts",
    "docker:up": "docker compose -f docker/docker-compose.yml --env-file docker/.env up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml --env-file docker/.env down",
    "docker:logs": "docker compose -f docker/docker-compose.yml --env-file docker/.env logs -f",
    "docker:ps": "docker compose -f docker/docker-compose.yml --env-file docker/.env ps",
    "docker:restart": "docker compose -f docker/docker-compose.yml --env-file docker/.env restart",
    "deploy": "npm run build && pm2 restart ecosystem.config.js",
    "prod:start": "pm2 start ecosystem.config.js",
    "prod:stop": "pm2 stop imopanorama",
    "prod:logs": "pm2 logs imopanorama",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-table": "^8.21.3",
    "@types/swagger-ui-react": "^5.18.0",
    "better-auth": "^1.6.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.22",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.562.0",
    "maplibre-gl": "^5.6.1",
    "next": "^16.0.0",
    "nodemailer": "^8.0.10",
    "openai": "^6.3.0",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.5.2",
    "swagger-ui-react": "^5.32.6",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/nodemailer": "^7.0.3",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "happy-dom": "^20.0.10",
    "postcss": "^8.5.6",
    "prisma": "^7.8.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.14",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "react-copy-to-clipboard": {
      "react": "$react"
    },
    "react-debounce-input": {
      "react": "$react"
    },
    "react-inspector": {
      "react": "$react"
    }
  }
}

# ImoPanorama - Coolify production environment
# Copy these keys into the Coolify application Environment Variables screen.
# Replace placeholder values with the values generated by Coolify.

# Runtime
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Public application URL
# Must match the production domain configured on the Coolify app.
NEXT_PUBLIC_APP_URL=https://imopanorama.mg
BETTER_AUTH_URL=https://imopanorama.mg

# Authentication
# Generate a strong secret and keep it locked in Coolify.
BETTER_AUTH_SECRET=replace_with_strong_random_secret

# PostgreSQL
# Use the INTERNAL URL when the app and database are on the same Coolify destination/network.
# This database must support pgvector. Prefer a pgvector/pgvector:pg16 service if Coolify's
# one-click PostgreSQL image does not include the vector extension.
DATABASE_URL=postgresql://USER:PASSWORD@POSTGRES_INTERNAL_HOST:5432/DATABASE?schema=public

# Redis
# Use the INTERNAL URL when the app and Redis are on the same Coolify destination/network.
REDIS_URL=redis://:PASSWORD@REDIS_INTERNAL_HOST:6379

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=contact@imopanorama.mg
ADMIN_EMAIL=admin@imopanorama.mg

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# BunnyCDN uploads
BUNNYCDN_STORAGE_ZONE_NAME=
BUNNYCDN_API_KEY=
BUNNYCDN_PULL_ZONE_URL=
NEXT_PUBLIC_BUNNYCDN_PULL_ZONE_URL=

# OpenAI semantic search (optional but recommended for embeddings)
OPENAI_API_KEY=

# Anti-spam
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Analytics / monitoring
NEXT_PUBLIC_UMAMI_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_GRAFANA_URL=

# Market defaults
NEXT_PUBLIC_DEFAULT_MARKET=MG

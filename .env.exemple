# Database Configuration (Prisma)
# Replace with your actual PostgreSQL connection string.
DATABASE_URL="postgresql://postgres:password@localhost:5432/imopanorama?schema=public"

# Authentication (Better Auth)
# Generate a secure random string for the secret, for example with: openssl rand -base64 32
BETTER_AUTH_SECRET="your_generated_secret_here"
BETTER_AUTH_URL="http://localhost:3000"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email Service
# Use Mailtrap in development, then a real SMTP provider in production.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="contact@imopanorama.mg"
ADMIN_EMAIL="admin@imopanorama.mg"

# Optional Mailtrap compatibility for older local setup.
MAILTRAP_HOST="sandbox.smtp.mailtrap.io"
MAILTRAP_PORT="2525"
MAILTRAP_USER=""
MAILTRAP_PASS=""

# Cache / rate limit backend
REDIS_URL="redis://localhost:6379"

# OpenAI (semantic property search via pgvector)
# Required to generate property embeddings on create/update and at query time.
OPENAI_API_KEY=""

# Storage (BunnyCDN)
# Required for image uploads.
BUNNYCDN_STORAGE_ZONE_NAME=""
BUNNYCDN_API_KEY=""
BUNNYCDN_PULL_ZONE_URL=""
NEXT_PUBLIC_BUNNYCDN_PULL_ZONE_URL=""

# Anti-spam
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# Analytics / monitoring
NEXT_PUBLIC_UMAMI_URL=""
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
NEXT_PUBLIC_GRAFANA_URL=""

# Market defaults
NEXT_PUBLIC_DEFAULT_MARKET="MG"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
